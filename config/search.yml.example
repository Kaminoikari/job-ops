# 104 搜尋條件
# 注意：搜尋只是「廣度撈取」；真正的納入門檻是 JD/title 必須出現 AI 關鍵字
#（沒有 AI 訊號的職缺會在 job_ops/ai_intent.py 的 has_ai 門檻一律剔除）。
keywords:
  # AI PM 高權重目標角色（req: 列為高權重關鍵字）
  - AI 產品經理
  - AI Product Manager
  - AI Product Builder
  - 產品總監
  - 產品長
  - Product Builder
  # 寬詞（PM 紅海大詞；104 是相關性排序，冷門領域的 PM 缺在寬詞下易排到數百名外）
  - 產品經理
  - Product Manager
  - 資深產品經理
  # 領域窄詞：撈出 title 被 AI/領域字稀釋、在 PM 寬詞下排序沉底的缺
  # （例：「AI 產品經理_先進工業電腦視覺」在「產品經理」排 865 名，在「電腦視覺」排第 9 名）
  - 電腦視覺

# 104 職務類別代碼（職類精準涵蓋，撈 title 不含關鍵字但職類掛 PM 的缺）
# 代碼查 https://static.104.com.tw/category-tool/json/JobCat.json
# 注意：jobcat 一樣按更新日降序，對「排序沉底」無幫助，是廣度補強而非深度
jobcats:
  - "2004003009"      # 產品經理
  - "2004003004"      # 其他專案管理師

areas:
  - 台北市
  - 新北市
  - 新竹市
  - 海外地區          # 含中國、日本、東南亞、北美、歐洲等所有海外職缺

# 每組 keyword / jobcat 最多翻幾頁（每頁約 20 筆）
# 第一次撈歷史可以拉高到 50；日常運作 5 通常足夠
max_pages_per_keyword: 5

# 只保留 appearDate >= 此日期的職缺；YYYY-MM-DD
# 第一次 bootstrap 撈歷史時設定（例如 "2026-04-01"），日常運作可註解掉或設為 null
# 翻頁時若整頁都早於此日期會 early-stop 加速
from_date: null

# 過濾條件
filters:
  # 月薪低於此值剔除；單位：新台幣
  min_salary_monthly: 60000

  # 「面議」/「待遇面議」職缺一律保留（不被 min_salary_monthly 剔除）
  include_negotiable_salary: true

  # 職位名稱包含這些字詞 → 排除
  exclude_keywords:
    - 實習
    - 兼職
    - 工讀
    - 派遣

  # 公司名稱包含這些字詞 → 排除
  exclude_companies: []
